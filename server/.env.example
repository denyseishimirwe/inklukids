# Copy to .env and fill in real values (never commit .env).
# PowerShell: Copy-Item .env.example .env

PORT=5000
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/inklukids?retryWrites=true&w=majority

# Use long random strings (at least 16 characters each).
JWT_ACCESS_SECRET=replace_with_long_random_secret_min_16
JWT_REFRESH_SECRET=replace_with_different_long_random_secret

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Frontend origin(s). Comma-separated for multiple (e.g. Vercel preview + prod).
CLIENT_ORIGIN=http://localhost:3000

# false for local SPA+API; true when API and SPA are on different hosts (Vercel + Render, HTTPS).
REFRESH_COOKIE_CROSS_SITE=false
