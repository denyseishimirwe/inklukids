# Server (Node/Express) environment variables
# Copy to `server/.env` for local dev. Do not commit real secrets.

# Network
PORT=5000

# Database
# Local MongoDB example:
# MONGO_URI=mongodb://127.0.0.1:27017/inklukids
MONGO_URI=

# Auth secrets (use 32+ random characters in production)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Token lifetime
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# CORS
# Allowed browser origins. Comma-separated list.
# Examples:
# CLIENT_ORIGIN=http://localhost:3000
# CLIENT_ORIGIN=https://your-frontend.vercel.app,https://www.yourdomain.com
CLIENT_ORIGIN=http://localhost:3000

# If frontend and API are on different site names, set true (requires HTTPS on the API).
# This makes the refresh cookie `SameSite=None; Secure`.
REFRESH_COOKIE_CROSS_SITE=false

