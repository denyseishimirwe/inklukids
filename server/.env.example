PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/inklukids
JWT_ACCESS_SECRET=change-me-access-at-least-16-chars
JWT_REFRESH_SECRET=change-me-refresh-at-least-16-chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
# Must match the browser origin of the React app (scheme + host + port).
CLIENT_ORIGIN=http://localhost:3000
# If the SPA and API are on different domains, set true and use HTTPS on the API (SameSite=None; Secure).
# REFRESH_COOKIE_CROSS_SITE=true

# Frontend production build: set to your public API URL before `npm run build`.
# REACT_APP_API_BASE=https://your-api.example.com

